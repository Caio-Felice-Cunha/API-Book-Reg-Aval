# Copy to .env and adjust for your environment. Do not commit .env.
# The app reads these via os.environ in core/settings.py.

# Django signing key. Generate a fresh one for any real deployment:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-dev-only-change-me

# 1 = debug on (local dev), 0 = debug off (production).
DJANGO_DEBUG=1

# Comma-separated hosts, required when DJANGO_DEBUG=0. Example:
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_ALLOWED_HOSTS=
